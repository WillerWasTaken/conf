# Mako notification daemon config
# Migrated from dunst config

# Display
max-visible=5
sort=-time
anchor=top-right
margin=5,5,0
# Offset from top to clear waybar (height 27 + gap)
padding=8
default-timeout=5000
ignore-timeout=0

# Appearance
font=Iosevka 10
width=300
border-size=1
border-color=#4287f5
border-radius=15
background-color=#202632
text-color=#ffffff

# Format
format=<b>%a</b>\n<i>%s</i>\n%b

# Grouping (stack duplicates)
group-by=app-name,summary

# Icons
icons=0

# Actions
on-button-left=dismiss
on-button-middle=invoke-default-action
on-button-right=invoke-default-action

[urgency=critical]
background-color=#ffffff
text-color=#db0101
default-timeout=0

[mode=do-not-disturb]
invisible=1
